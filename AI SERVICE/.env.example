# ExamPilot AI Service — Environment Configuration Template
# Copy this file to .env and fill in your actual values.

# ===============================
# SERVER SETTINGS
# ===============================
HOST=127.0.0.1
PORT=8000
ENV=development

# ===============================
# STORAGE DIRECTORIES
# ===============================
UPLOAD_DIR=uploads
ARCHIVE_DIR=archive
OUTPUT_DIR=output

# ===============================
# GOOGLE GEMINI API
# ===============================
GEMINI_API_KEY=your_gemini_api_key_here

# ===============================
# CLOUDINARY (Diagram Image Storage)
# ===============================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
