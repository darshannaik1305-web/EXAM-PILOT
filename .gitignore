# Credentials & private settings
.env
.env.*
*.env
credentials.json
client_secret*.json

# Python Virtual Environments (global)
**/venv/
**/.venv/
**/env/
**/ENV/

# Python compiled files / caching (global)
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.ipynb_checkpoints/

# System Log files
**/*.log

# IDE & Editor configurations
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.suo
*.ntvs*
*.njsproj
*.sln

# Transient storage / output directories (global)
**/uploads/*
!**/uploads/.gitkeep
**/output/*
!**/output/.gitkeep
**/archive/*
!**/archive/.gitkeep

# Java / Maven Build outputs
**/target/
build/
.mvn/wrapper/maven-wrapper.jar
.sts4-cache/
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans

# Node/JavaScript & Vite Build outputs
**/node_modules/
**/dist/
**/dist-ssr/
**/*.local
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/.eslintcache

# Operating System files
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# Local storage and diagram crops
storage/diagrams/*
!storage/diagrams/.gitkeep
