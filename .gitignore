# ===============================
# Credentials & Private Settings
# ===============================
.env
.env.*
*.env
!.env.example
credentials.json
client_secret*.json

# ===============================
# Python Virtual Environment
# ===============================
**/venv/
**/.venv/
**/env/
**/ENV/

# ===============================
# Python Compiled Files / Cache
# ===============================
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.pytest_cache/
.ipynb_checkpoints/

# ===============================
# System Log Files
# ===============================
**/*.log

# ===============================
# IDE & Editor Configurations
# ===============================
.idea/
.vscode/
*.iml
*.iws
*.ipr
*.suo
*.ntvs*
*.njsproj
*.sln

# ===============================
# Transient Storage / Output Directories
# ===============================
**/uploads/*
!**/uploads/.gitkeep
**/output/*
!**/output/.gitkeep
**/archive/*
!**/archive/.gitkeep

# ===============================
# Java / Maven Build Outputs
# ===============================
**/target/
build/
.mvn/wrapper/maven-wrapper.jar
.sts4-cache/
.apt_generated/
.classpath
.factorypath
.project
.settings/
.springBeans

# ===============================
# Node / JavaScript & Vite Build Outputs
# ===============================
**/node_modules/
**/dist/
**/dist-ssr/
**/*.local
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*
**/.eslintcache

# ===============================
# Operating System Files
# ===============================
**/.DS_Store
**/Thumbs.db
**/desktop.ini

# ===============================
# Local Diagram Crops (served via Cloudinary in production)
# ===============================
storage/diagrams/*
!storage/diagrams/.gitkeep
