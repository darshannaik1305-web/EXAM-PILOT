# ExamPilot Backend — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# These are loaded as environment variables by Spring Boot via application.properties.

# ===============================
# SUPABASE / POSTGRESQL DATABASE
# ===============================
SPRING_DATASOURCE_URL=jdbc:postgresql://your-supabase-host.supabase.com:5432/postgres
SPRING_DATASOURCE_USERNAME=postgres.your_project_ref
SPRING_DATASOURCE_PASSWORD=your_database_password

# ===============================
# JWT SECRET (generate a strong random string)
# ===============================
JWT_SECRET=your_jwt_secret_key_here
